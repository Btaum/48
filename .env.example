# Required on Render/VPS to lock the dashboard
DASHBOARD_PASSWORD=change-this-to-a-strong-password

# Optional: keeps login sessions valid across restarts
DASHBOARD_SESSION_SECRET=change-this-to-a-long-random-secret

# Optional: session lifetime in hours
DASHBOARD_SESSION_HOURS=12

# Optional on Render/VPS: persistent Delta credentials without writing data/apiKeys.json
DELTA_API_KEY=
DELTA_API_SECRET=
